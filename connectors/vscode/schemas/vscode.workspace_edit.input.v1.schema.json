{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vscode.workspace_edit.input.v1",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["document_uri", "edits"],
      "properties": {
        "document_uri": {"type": "string", "pattern": "^file:"},
        "edits": {
          "type": "array", "minItems": 1, "maxItems": 64,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["range", "new_text"],
            "properties": {"range": {"$ref": "#/$defs/range"}, "new_text": {"type": "string", "maxLength": 262144}}
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["reversal_token"],
      "properties": {"reversal_token": {"type": "string", "minLength": 1, "maxLength": 128}}
    }
  ],
  "$defs": {
    "position": {
      "type": "object", "additionalProperties": false,
      "required": ["line", "character"],
      "properties": {"line": {"type": "integer", "minimum": 0}, "character": {"type": "integer", "minimum": 0}}
    },
    "range": {
      "type": "object", "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {"start": {"$ref": "#/$defs/position"}, "end": {"$ref": "#/$defs/position"}}
    }
  }
}
