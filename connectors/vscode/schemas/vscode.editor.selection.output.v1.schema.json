{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vscode.editor.selection.output.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["document_uri", "language_id", "document_version", "selection", "text", "text_truncated"],
  "properties": {
    "document_uri": {"type": "string"},
    "language_id": {"type": "string"},
    "document_version": {"type": "integer", "minimum": 1},
    "selection": {"$ref": "#/$defs/range"},
    "text": {"type": "string", "maxLength": 131072},
    "text_truncated": {"type": "boolean"}
  },
  "$defs": {
    "position": {
      "type": "object", "additionalProperties": false,
      "required": ["line", "character"],
      "properties": {"line": {"type": "integer", "minimum": 0}, "character": {"type": "integer", "minimum": 0}}
    },
    "range": {
      "type": "object", "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {"start": {"$ref": "#/$defs/position"}, "end": {"$ref": "#/$defs/position"}}
    }
  }
}
