{
  "$defs": {
    "ShellAskCommand": {
      "additionalProperties": false,
      "properties": {
        "contexts": {
          "items": {
            "$ref": "#/$defs/ShellContext"
          },
          "type": "array"
        },
        "contract_version": {
          "const": "fam.shell/v1alpha1"
        },
        "prompt": {
          "type": "string"
        },
        "request_id": {
          "type": "string"
        },
        "required_capabilities": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "verification_required": {
          "type": "boolean"
        }
      },
      "required": [
        "request_id",
        "prompt",
        "contexts",
        "required_capabilities",
        "verification_required",
        "contract_version"
      ],
      "type": "object"
    },
    "ShellContext": {
      "additionalProperties": false,
      "properties": {
        "capability_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "context_id": {
          "type": "string"
        },
        "display_name": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "application",
            "file",
            "selection",
            "uri"
          ],
          "type": "string"
        },
        "resource_ref": {
          "type": "string"
        }
      },
      "required": [
        "context_id",
        "kind",
        "resource_ref",
        "display_name",
        "capability_ids"
      ],
      "type": "object"
    }
  },
  "$id": "https://schemas.fam-os.local/fam.shell.ask/v1alpha1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "const": "fam.shell/v1alpha1"
    },
    "payload": {
      "$ref": "#/$defs/ShellAskCommand"
    },
    "schema_id": {
      "const": "fam.shell.ask/v1alpha1"
    }
  },
  "required": [
    "schema_id",
    "contract_version",
    "payload"
  ],
  "title": "FAM Shell ask command",
  "type": "object"
}
