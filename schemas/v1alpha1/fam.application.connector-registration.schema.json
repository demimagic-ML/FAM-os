{
  "$defs": {
    "ApplicationIdentity": {
      "additionalProperties": false,
      "properties": {
        "application_id": {
          "type": "string"
        },
        "display_name": {
          "type": "string"
        },
        "vendor": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "application_id",
        "display_name",
        "vendor",
        "version"
      ],
      "type": "object"
    },
    "ApplicationInstance": {
      "additionalProperties": false,
      "properties": {
        "application": {
          "$ref": "#/$defs/ApplicationIdentity"
        },
        "connector_id": {
          "type": "string"
        },
        "instance_id": {
          "type": "string"
        },
        "process_id": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        },
        "workspace_uris": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "instance_id",
        "application",
        "connector_id",
        "process_id",
        "workspace_uris"
      ],
      "type": "object"
    },
    "CapabilityDescriptor": {
      "additionalProperties": false,
      "properties": {
        "capability_id": {
          "type": "string"
        },
        "confirmation": {
          "enum": [
            "not_required",
            "when_required",
            "always"
          ],
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "display_name": {
          "type": "string"
        },
        "input_schema_id": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "observation",
            "action"
          ],
          "type": "string"
        },
        "output_schema_id": {
          "type": "string"
        },
        "postcondition_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "required_authority": {
          "enum": [
            "observe",
            "propose",
            "modify",
            "execute"
          ],
          "type": "string"
        },
        "reversibility": {
          "enum": [
            "not_applicable",
            "reversible",
            "compensatable",
            "irreversible"
          ],
          "type": "string"
        }
      },
      "required": [
        "capability_id",
        "display_name",
        "description",
        "kind",
        "required_authority",
        "input_schema_id",
        "output_schema_id",
        "reversibility",
        "confirmation",
        "postcondition_ids"
      ],
      "type": "object"
    },
    "CapabilityRegistryEntry": {
      "additionalProperties": false,
      "properties": {
        "application_id": {
          "type": "string"
        },
        "available": {
          "type": "boolean"
        },
        "capability": {
          "$ref": "#/$defs/CapabilityDescriptor"
        },
        "connector_id": {
          "type": "string"
        },
        "entry_id": {
          "type": "string"
        },
        "instance_id": {
          "type": "string"
        },
        "resource_scopes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "entry_id",
        "connector_id",
        "instance_id",
        "application_id",
        "capability",
        "resource_scopes",
        "available"
      ],
      "type": "object"
    },
    "ConnectorRegistration": {
      "additionalProperties": false,
      "properties": {
        "capabilities": {
          "items": {
            "$ref": "#/$defs/CapabilityRegistryEntry"
          },
          "type": "array"
        },
        "connected_at": {
          "format": "date-time",
          "type": "string"
        },
        "connector_id": {
          "type": "string"
        },
        "contract_version": {
          "const": "fam.applications/v1alpha1"
        },
        "instance": {
          "$ref": "#/$defs/ApplicationInstance"
        },
        "protocol_id": {
          "type": "string"
        },
        "protocol_version": {
          "type": "string"
        },
        "transport_kind": {
          "enum": [
            "native_local",
            "mcp_local",
            "os_tool",
            "accessibility",
            "screen_input"
          ],
          "type": "string"
        }
      },
      "required": [
        "connector_id",
        "transport_kind",
        "protocol_id",
        "protocol_version",
        "instance",
        "capabilities",
        "connected_at",
        "contract_version"
      ],
      "type": "object"
    }
  },
  "$id": "https://schemas.fam-os.local/fam.application.connector-registration/v1alpha1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "const": "fam.applications/v1alpha1"
    },
    "payload": {
      "$ref": "#/$defs/ConnectorRegistration"
    },
    "schema_id": {
      "const": "fam.application.connector-registration/v1alpha1"
    }
  },
  "required": [
    "schema_id",
    "contract_version",
    "payload"
  ],
  "title": "Application connector registration",
  "type": "object"
}
