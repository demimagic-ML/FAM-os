{
  "$defs": {
    "ApplicationFailure": {
      "additionalProperties": false,
      "properties": {
        "category": {
          "enum": [
            "permission_denied",
            "unavailable",
            "precondition_failed",
            "execution_failed",
            "postcondition_failed",
            "cancelled"
          ],
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "contract_version": {
          "const": "fam.application.failure/v1alpha1"
        },
        "evidence_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "retry": {
          "enum": [
            "never",
            "immediate",
            "with_backoff",
            "after_user_action",
            "after_state_change"
          ],
          "type": "string"
        },
        "safe_message": {
          "type": "string"
        }
      },
      "required": [
        "category",
        "code",
        "safe_message",
        "retry",
        "evidence_ids",
        "contract_version"
      ],
      "type": "object"
    },
    "JsonValue": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "string"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "items": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        }
      ]
    },
    "ObservationResult": {
      "additionalProperties": false,
      "properties": {
        "error": {
          "anyOf": [
            {
              "$ref": "#/$defs/ApplicationFailure"
            },
            {
              "type": "null"
            }
          ]
        },
        "observed_at": {
          "format": "date-time",
          "type": "string"
        },
        "payload": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        },
        "request_id": {
          "type": "string"
        },
        "resource_uri": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "revision": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "status": {
          "enum": [
            "observed",
            "denied",
            "unavailable",
            "failed"
          ],
          "type": "string"
        }
      },
      "required": [
        "request_id",
        "status",
        "observed_at",
        "payload",
        "resource_uri",
        "revision",
        "error"
      ],
      "type": "object"
    }
  },
  "$id": "https://schemas.fam-os.local/fam.application.observation-result/v1alpha1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "const": "fam.applications/v1alpha1"
    },
    "payload": {
      "$ref": "#/$defs/ObservationResult"
    },
    "schema_id": {
      "const": "fam.application.observation-result/v1alpha1"
    }
  },
  "required": [
    "schema_id",
    "contract_version",
    "payload"
  ],
  "title": "Application observation result",
  "type": "object"
}
