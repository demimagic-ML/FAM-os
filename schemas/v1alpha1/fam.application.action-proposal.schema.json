{
  "$defs": {
    "ActionPreparationRequest": {
      "additionalProperties": false,
      "properties": {
        "capability_id": {
          "type": "string"
        },
        "expected_revision": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "instance_id": {
          "type": "string"
        },
        "parameters": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        },
        "permission_grant_id": {
          "type": "string"
        },
        "request_id": {
          "type": "string"
        },
        "resource_uri": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "summary": {
          "type": "string"
        }
      },
      "required": [
        "request_id",
        "instance_id",
        "capability_id",
        "permission_grant_id",
        "summary",
        "parameters",
        "resource_uri",
        "expected_revision"
      ],
      "type": "object"
    },
    "ActionProposal": {
      "additionalProperties": false,
      "properties": {
        "confirmation": {
          "enum": [
            "not_required",
            "when_required",
            "always"
          ],
          "type": "string"
        },
        "postconditions": {
          "items": {
            "$ref": "#/$defs/ConditionRequirement"
          },
          "type": "array"
        },
        "preconditions": {
          "items": {
            "$ref": "#/$defs/ConditionRequirement"
          },
          "type": "array"
        },
        "preview": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        },
        "proposal_id": {
          "type": "string"
        },
        "request": {
          "$ref": "#/$defs/ActionPreparationRequest"
        },
        "reversal_capability_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "reversibility": {
          "enum": [
            "not_applicable",
            "reversible",
            "compensatable",
            "irreversible"
          ],
          "type": "string"
        }
      },
      "required": [
        "proposal_id",
        "request",
        "preview",
        "reversibility",
        "confirmation",
        "postconditions",
        "preconditions",
        "reversal_capability_id"
      ],
      "type": "object"
    },
    "ConditionRequirement": {
      "additionalProperties": false,
      "properties": {
        "condition_id": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "verifier_id": {
          "type": "string"
        }
      },
      "required": [
        "condition_id",
        "verifier_id",
        "description"
      ],
      "type": "object"
    },
    "JsonValue": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "string"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "items": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        }
      ]
    }
  },
  "$id": "https://schemas.fam-os.local/fam.application.action-proposal/v1alpha1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "const": "fam.applications/v1alpha1"
    },
    "payload": {
      "$ref": "#/$defs/ActionProposal"
    },
    "schema_id": {
      "const": "fam.application.action-proposal/v1alpha1"
    }
  },
  "required": [
    "schema_id",
    "contract_version",
    "payload"
  ],
  "title": "Application action proposal",
  "type": "object"
}
