{
  "$defs": {
    "MicroExpertBenchmarkReport": {
      "additionalProperties": false,
      "properties": {
        "contract_version": {
          "const": "fam.expert.micro-advice/v1alpha1"
        },
        "minimum_accuracy_millionths": {
          "type": "integer"
        },
        "passed": {
          "type": "boolean"
        },
        "results": {
          "items": {
            "$ref": "#/$defs/MicroExpertBenchmarkResult"
          },
          "type": "array"
        },
        "suite_id": {
          "type": "string"
        }
      },
      "required": [
        "suite_id",
        "results",
        "minimum_accuracy_millionths",
        "passed",
        "contract_version"
      ],
      "type": "object"
    },
    "MicroExpertBenchmarkResult": {
      "additionalProperties": false,
      "properties": {
        "accuracy_millionths": {
          "type": "integer"
        },
        "case_count": {
          "type": "integer"
        },
        "contract_version": {
          "const": "fam.expert.micro-advice/v1alpha1"
        },
        "correct_count": {
          "type": "integer"
        },
        "expert_id": {
          "type": "string"
        },
        "fixture_sha256": {
          "type": "string"
        }
      },
      "required": [
        "expert_id",
        "case_count",
        "correct_count",
        "accuracy_millionths",
        "fixture_sha256",
        "contract_version"
      ],
      "type": "object"
    }
  },
  "$id": "https://schemas.fam-os.local/fam.expert.micro-benchmark/v1alpha1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "const": "fam.expert.micro-advice/v1alpha1"
    },
    "payload": {
      "$ref": "#/$defs/MicroExpertBenchmarkReport"
    },
    "schema_id": {
      "const": "fam.expert.micro-benchmark/v1alpha1"
    }
  },
  "required": [
    "schema_id",
    "contract_version",
    "payload"
  ],
  "title": "Micro-expert benchmark report",
  "type": "object"
}
