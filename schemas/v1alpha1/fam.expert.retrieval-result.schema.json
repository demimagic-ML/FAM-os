{
  "$defs": {
    "RankedRetrievalSource": {
      "additionalProperties": false,
      "properties": {
        "combined_score": {
          "type": "number"
        },
        "lexical_score": {
          "type": "number"
        },
        "rank": {
          "type": "integer"
        },
        "semantic_score": {
          "type": "number"
        },
        "source": {
          "$ref": "#/$defs/RetrievedSource"
        }
      },
      "required": [
        "source",
        "semantic_score",
        "lexical_score",
        "combined_score",
        "rank"
      ],
      "type": "object"
    },
    "RetrievalCitation": {
      "additionalProperties": false,
      "properties": {
        "citation_id": {
          "type": "string"
        },
        "end_character": {
          "type": "integer"
        },
        "quoted_text_sha256": {
          "type": "string"
        },
        "source_id": {
          "type": "string"
        },
        "start_character": {
          "type": "integer"
        }
      },
      "required": [
        "citation_id",
        "source_id",
        "start_character",
        "end_character",
        "quoted_text_sha256"
      ],
      "type": "object"
    },
    "RetrievalClaim": {
      "additionalProperties": false,
      "properties": {
        "citation_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "claim_id": {
          "type": "string"
        }
      },
      "required": [
        "claim_id",
        "citation_ids"
      ],
      "type": "object"
    },
    "RetrievalVerificationReport": {
      "additionalProperties": false,
      "properties": {
        "contract_version": {
          "const": "fam.verifier.retrieval/v1alpha1"
        },
        "passed": {
          "type": "boolean"
        },
        "reason_codes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "rejected_claim_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "verification_id": {
          "type": "string"
        },
        "verified_claim_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "verification_id",
        "verified_claim_ids",
        "rejected_claim_ids",
        "reason_codes",
        "passed",
        "contract_version"
      ],
      "type": "object"
    },
    "RetrievedSource": {
      "additionalProperties": false,
      "properties": {
        "content": {
          "type": "string"
        },
        "content_sha256": {
          "type": "string"
        },
        "locator": {
          "type": "string"
        },
        "provenance_id": {
          "type": "string"
        },
        "source_id": {
          "type": "string"
        }
      },
      "required": [
        "source_id",
        "locator",
        "content",
        "content_sha256",
        "provenance_id"
      ],
      "type": "object"
    },
    "SynthesisResult": {
      "additionalProperties": false,
      "properties": {
        "answer": {
          "type": "string"
        },
        "citations": {
          "items": {
            "$ref": "#/$defs/RetrievalCitation"
          },
          "type": "array"
        },
        "claims": {
          "items": {
            "$ref": "#/$defs/RetrievalClaim"
          },
          "type": "array"
        },
        "model_ref": {
          "type": "string"
        }
      },
      "required": [
        "answer",
        "claims",
        "citations",
        "model_ref"
      ],
      "type": "object"
    },
    "VerifiedRetrievalResult": {
      "additionalProperties": false,
      "properties": {
        "contract_version": {
          "const": "fam.expert.retrieval-tiers/v1alpha1"
        },
        "query": {
          "type": "string"
        },
        "ranked_sources": {
          "items": {
            "$ref": "#/$defs/RankedRetrievalSource"
          },
          "type": "array"
        },
        "released": {
          "type": "boolean"
        },
        "synthesis": {
          "$ref": "#/$defs/SynthesisResult"
        },
        "verification": {
          "$ref": "#/$defs/RetrievalVerificationReport"
        }
      },
      "required": [
        "query",
        "ranked_sources",
        "synthesis",
        "verification",
        "released",
        "contract_version"
      ],
      "type": "object"
    }
  },
  "$id": "https://schemas.fam-os.local/fam.expert.retrieval-result/v1alpha1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "const": "fam.expert.retrieval-tiers/v1alpha1"
    },
    "payload": {
      "$ref": "#/$defs/VerifiedRetrievalResult"
    },
    "schema_id": {
      "const": "fam.expert.retrieval-result/v1alpha1"
    }
  },
  "required": [
    "schema_id",
    "contract_version",
    "payload"
  ],
  "title": "Verified three-tier retrieval result",
  "type": "object"
}
