        "consumed_tokens",
        "consumed_wall_milliseconds",
        "repairs",
        "escalations",
        "reservation_ids"
      ],
      "type": "object"
    },
    "EscalationTraceReport": {
      "additionalProperties": false,
      "properties": {
        "acceptance_id": {
          "type": "string"
        },
        "attempt_kinds": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "contract_version": {
          "const": "fam.expert.escalation-trace/v1alpha1"
        },
        "economical_model_ref": {
          "type": "string"
        },
        "escalation_expert_id": {
          "type": "string"
        },
        "escalation_model_ref": {
          "type": "string"
        },
        "global_budget": {
          "$ref": "#/$defs/EscalationBudgetEvidence"
        },
        "maximum_failure_feedback_characters": {
          "type": "integer"
        },
        "package_artifact_sha256": {
          "type": "string"
        },
        "raw_report_sha256": {
          "type": "string"
        },
        "repair_examples_sha256": {
          "type": "string"
        },
        "trace_id": {
          "type": "string"
        },
        "trusted_tests_sha256": {
          "type": "string"
        },
        "verification_statuses": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "verified": {
          "type": "boolean"
        }
      },
      "required": [
        "trace_id",
        "economical_model_ref",
        "escalation_model_ref",
        "escalation_expert_id",
        "package_artifact_sha256",
        "attempt_kinds",
        "verification_statuses",
        "acceptance_id",
        "trusted_tests_sha256",
        "repair_examples_sha256",
        "maximum_failure_feedback_characters",
        "global_budget",
        "verified",
        "raw_report_sha256",
        "contract_version"
      ],
      "type": "object"
    }
