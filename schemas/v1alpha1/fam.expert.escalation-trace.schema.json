    "EscalationBudgetEvidence": {
      "additionalProperties": false,
      "properties": {
        "consumed_tokens": {
          "type": "integer"
        },
        "consumed_wall_milliseconds": {
          "type": "integer"
        },
        "escalations": {
          "type": "integer"
        },
        "repairs": {
          "type": "integer"
        },
        "reservation_ids": {
