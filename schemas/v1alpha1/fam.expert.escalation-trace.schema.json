  "$id": "https://schemas.fam-os.local/fam.expert.escalation-trace/v1alpha1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "const": "fam.expert.escalation-trace/v1alpha1"
    },
    "payload": {
