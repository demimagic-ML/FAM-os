    },
    "schema_id": {
      "const": "fam.expert.escalation-trace/v1alpha1"
    }
  },
  "required": [
    "schema_id",
    "contract_version",
    "payload"
  ],
  "title": "Code escalation trace",
  "type": "object"
}
