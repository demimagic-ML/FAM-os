{
  "$defs": {
    "ApplicationIdentity": {
      "additionalProperties": false,
      "properties": {
        "application_id": {
          "type": "string"
        },
        "display_name": {
          "type": "string"
        },
        "vendor": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "application_id",
        "display_name",
        "vendor",
        "version"
      ],
      "type": "object"
    },
    "ApplicationInstance": {
      "additionalProperties": false,
      "properties": {
        "application": {
          "$ref": "#/$defs/ApplicationIdentity"
        },
        "connector_id": {
          "type": "string"
        },
        "instance_id": {
          "type": "string"
        },
        "process_id": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        },
        "workspace_uris": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "instance_id",
        "application",
        "connector_id",
        "process_id",
        "workspace_uris"
      ],
      "type": "object"
    }
  },
  "$id": "https://schemas.fam-os.local/fam.application.instance/v1alpha1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "const": "fam.applications/v1alpha1"
    },
    "payload": {
      "$ref": "#/$defs/ApplicationInstance"
    },
    "schema_id": {
      "const": "fam.application.instance/v1alpha1"
    }
  },
  "required": [
    "schema_id",
    "contract_version",
    "payload"
  ],
  "title": "Application instance",
  "type": "object"
}
