    "ArtifactAccessSequence": {
      "additionalProperties": false,
      "properties": {
        "artifact_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "observed_at": {
          "format": "date-time",
          "type": "string"
        },
        "sequence_id": {
          "type": "string"
        },
        "source_evidence_digest_sha256": {
          "type": "string"
        }
      },
      "required": [
        "sequence_id",
        "observed_at",
        "artifact_ids",
        "source_evidence_digest_sha256"
      ],
      "type": "object"
    },
    "CacheTelemetryEntry": {
      "additionalProperties": false,
      "properties": {
        "artifact_bytes": {
          "type": "integer"
        },
        "artifact_id": {
          "type": "string"
        },
        "evictable": {
          "type": "boolean"
        },
        "hit_count": {
          "type": "integer"
        },
        "last_accessed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "miss_count": {
          "type": "integer"
        },
        "observed_bytes": {
          "type": "integer"
        },
        "reload_cost_ms": {
          "type": "number"
        },
        "source_evidence_digest_sha256": {
          "type": "string"
        },
        "state": {
          "enum": [
            "cold",
            "warm",
            "active"
          ],
          "type": "string"
        },
        "tier": {
          "enum": [
            "host_page_cache",
            "provider_weights",
            "accelerator_weights",
            "npu_compiled"
          ],
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "tier",
        "state",
        "artifact_bytes",
        "observed_bytes",
        "hit_count",
        "miss_count",
        "last_accessed_at",
        "reload_cost_ms",
        "evictable",
        "source_evidence_digest_sha256"
      ],
      "type": "object"
    },
    "CacheTelemetrySnapshot": {
      "additionalProperties": false,
      "properties": {
        "contract_version": {
          "const": "fam.scheduler.cache-policy/v1alpha1"
        },
        "current_host_state_complete": {
          "type": "boolean"
