{
  "$defs": {
    "DegradationNotice": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "component": {
          "enum": [
            "core",
            "routing",
            "expert",
            "scheduler",
            "verification",
            "application",
            "memory",
            "supervisor",
            "registry",
            "adapter"
          ],
          "type": "string"
        },
        "contract_version": {
          "const": "fam.failure/v1alpha1"
        },
        "degradation_id": {
          "type": "string"
        },
        "disposition": {
          "enum": [
            "continue",
            "require_confirmation",
            "withhold"
          ],
          "type": "string"
        },
        "evidence_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "impact": {
          "enum": [
            "none",
            "unknown",
            "low",
            "medium",
            "high"
          ],
          "type": "string"
        },
        "kind": {
          "enum": [
            "fallback_used",
            "capability_unavailable",
            "resource_constrained",
            "context_reduced",
            "quality_reduced",
            "partial_result",
            "stale_data"
          ],
          "type": "string"
        },
        "original_capability_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "replacement_capability_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "safe_message": {
          "type": "string"
        }
      },
      "required": [
        "degradation_id",
        "kind",
        "code",
        "safe_message",
        "component",
        "impact",
        "disposition",
        "original_capability_id",
        "replacement_capability_id",
        "evidence_ids",
        "contract_version"
      ],
      "type": "object"
    }
  },
  "$id": "https://schemas.fam-os.local/fam.failure.degradation/v1alpha1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "const": "fam.failure/v1alpha1"
    },
    "payload": {
      "$ref": "#/$defs/DegradationNotice"
    },
    "schema_id": {
      "const": "fam.failure.degradation/v1alpha1"
    }
  },
  "required": [
    "schema_id",
    "contract_version",
    "payload"
  ],
  "title": "FAM degradation notice",
  "type": "object"
}
