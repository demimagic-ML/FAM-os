{
  "$defs": {
    "HostAcceleratorInventory": {
      "additionalProperties": false,
      "properties": {
        "device_id": {
          "type": "string"
        },
        "driver_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "kind": {
          "enum": [
            "gpu",
            "npu"
          ],
          "type": "string"
        },
        "memory_total_bytes": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "device_id",
        "kind",
        "name",
        "memory_total_bytes",
        "driver_version"
      ],
      "type": "object"
    },
    "HostCpuInventory": {
      "additionalProperties": false,
      "properties": {
        "architecture": {
          "type": "string"
        },
        "logical_cpu_ids": {
          "items": {
            "type": "integer"
          },
          "type": "array"
        },
        "model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "physical_core_count": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "architecture",
        "logical_cpu_ids",
        "model",
        "physical_core_count"
      ],
      "type": "object"
    },
    "HostInventory": {
      "additionalProperties": false,
      "properties": {
        "accelerators": {
          "items": {
            "$ref": "#/$defs/HostAcceleratorInventory"
          },
          "type": "array"
        },
        "captured_at": {
          "format": "date-time",
          "type": "string"
        },
        "contract_version": {
          "const": "fam.hardware.inventory/v1alpha1"
        },
        "cpu": {
          "$ref": "#/$defs/HostCpuInventory"
        },
        "inventory_id": {
          "type": "string"
        },
        "memory": {
          "$ref": "#/$defs/HostMemoryInventory"
        },
        "operating_system": {
          "type": "string"
        },
        "os_release": {
          "type": "string"
        },
        "storage": {
          "items": {
            "$ref": "#/$defs/HostStorageInventory"
          },
          "type": "array"
        }
      },
      "required": [
        "inventory_id",
        "captured_at",
        "operating_system",
        "os_release",
        "cpu",
        "memory",
        "storage",
        "accelerators",
        "contract_version"
      ],
      "type": "object"
    },
    "HostMemoryInventory": {
      "additionalProperties": false,
      "properties": {
        "available_bytes": {
          "type": "integer"
        },
        "swap_free_bytes": {
          "type": "integer"
        },
        "swap_total_bytes": {
          "type": "integer"
        },
        "total_bytes": {
          "type": "integer"
        }
      },
      "required": [
        "total_bytes",
        "available_bytes",
        "swap_total_bytes",
        "swap_free_bytes"
      ],
      "type": "object"
    },
    "HostStorageInventory": {
      "additionalProperties": false,
      "properties": {
        "available_bytes": {
          "type": "integer"
        },
        "cache_eligible": {
          "type": "boolean"
        },
        "capacity_bytes": {
          "type": "integer"
        },
        "medium": {
          "enum": [
            "nvme",
            "ssd",
            "hdd",
            "other"
          ],
          "type": "string"
        },
        "mount_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "storage_id": {
          "type": "string"
        }
      },
      "required": [
        "storage_id",
        "medium",
        "capacity_bytes",
        "available_bytes",
        "cache_eligible",
        "mount_path"
      ],
      "type": "object"
    }
  },
  "$id": "https://schemas.fam-os.local/fam.hardware.host-inventory/v1alpha1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "const": "fam.hardware.inventory/v1alpha1"
    },
    "payload": {
      "$ref": "#/$defs/HostInventory"
    },
    "schema_id": {
      "const": "fam.hardware.host-inventory/v1alpha1"
    }
  },
  "required": [
    "schema_id",
    "contract_version",
    "payload"
  ],
  "title": "Host inventory",
  "type": "object"
}
