{
  "$defs": {
    "ApplicationActionAuditIntent": {
      "additionalProperties": false,
      "properties": {
        "application_id": {
          "type": "string"
        },
        "capability_id": {
          "type": "string"
        },
        "condition_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "confirmation_id": {
          "type": "string"
        },
        "contract_version": {
          "const": "fam.application.action-audit/v1alpha1"
        },
        "event_id": {
          "type": "string"
        },
        "failure_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "instance_id": {
          "type": "string"
        },
        "occurred_at": {
          "format": "date-time",
          "type": "string"
        },
        "operation_id": {
          "type": "string"
        },
        "permission_grant_id": {
          "type": "string"
        },
        "plan_instance_id": {
          "type": "string"
        },
        "principal_id": {
          "type": "string"
        },
        "proposal_id": {
          "type": "string"
        },
        "request_id": {
          "type": "string"
        },
        "resource_sha256": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "result_status": {
          "anyOf": [
            {
              "enum": [
                "verified",
                "denied",
                "precondition_failed",
                "execution_failed",
                "postcondition_failed",
                "cancelled"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "reversal_available": {
          "type": "boolean"
        },
        "reversal_capability_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "session_id": {
          "type": "string"
        },
        "stage": {
          "enum": [
            "requested",
            "precondition_failed",
            "execution_failed",
            "postcondition_failed",
            "verified"
          ],
          "type": "string"
        }
      },
      "required": [
        "event_id",
        "operation_id",
        "occurred_at",
        "request_id",
        "plan_instance_id",
        "principal_id",
        "session_id",
        "application_id",
        "instance_id",
        "capability_id",
        "permission_grant_id",
        "proposal_id",
        "confirmation_id",
        "stage",
        "resource_sha256",
        "condition_ids",
        "result_status",
        "reversal_capability_id",
        "reversal_available",
        "failure_code",
        "contract_version"
      ],
      "type": "object"
    },
    "ApplicationActionAuditRecord": {
      "additionalProperties": false,
      "properties": {
        "digest": {
          "type": "string"
        },
        "intent": {
          "$ref": "#/$defs/ApplicationActionAuditIntent"
        },
        "previous_digest": {
          "type": "string"
        },
        "sequence": {
          "type": "integer"
        }
      },
      "required": [
        "sequence",
        "previous_digest",
        "digest",
        "intent"
      ],
      "type": "object"
    }
  },
  "$id": "https://schemas.fam-os.local/fam.application.action-audit-record/v1alpha1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "const": "fam.application.action-audit/v1alpha1"
    },
    "payload": {
      "$ref": "#/$defs/ApplicationActionAuditRecord"
    },
    "schema_id": {
      "const": "fam.application.action-audit-record/v1alpha1"
    }
  },
  "required": [
    "schema_id",
    "contract_version",
    "payload"
  ],
  "title": "Application action audit record",
  "type": "object"
}
